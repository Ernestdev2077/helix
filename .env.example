# ==========================================
# helix — Environment Variables (example)
# Copy this file to .env and fill in real values
# ==========================================

# --- Core ---
ENVIRONMENT=development                 # development | staging | production
DEBUG=true

# --- Django ---
DJANGO_SECRET_KEY=change-me-in-production-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Database ---
POSTGRES_DB=helix
POSTGRES_USER=helix
POSTGRES_PASSWORD=helix_password_change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://helix:helix_password_change_me@postgres:5432/helix

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CHANNELS_REDIS_URL=redis://redis:6379/3
AGENT_STREAM_REDIS_URL=redis://redis:6379/4

# --- Agent Service ---
AGENT_SERVICE_URL=http://agents:8001
AGENT_SERVICE_INTERNAL_TOKEN=change-me-to-shared-internal-secret

# --- LLM providers (LiteLLM routes among them) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# --- Observability ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=helix-dev
LANGSMITH_TRACING=false
SENTRY_DSN=

# --- Platform OAuth: X / Twitter ---
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:8000/api/auth/oauth/x/callback/

# --- Platform OAuth: Reddit ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=helix/0.1
REDDIT_REDIRECT_URI=http://localhost:8000/api/auth/oauth/reddit/callback/

# --- Platform OAuth: LinkedIn ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/auth/oauth/linkedin/callback/

# --- Storage (S3-compatible) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=helix-dev
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=us-east-1

# --- Billing (Stripe) ---
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Frontend ---
# In dev, leave these blank: Vite proxies /api and /ws to the backend, so
# requests are same-origin and you avoid CORS entirely. Set explicit URLs
# in staging/prod where SPA and API live on different origins.
VITE_API_URL=
VITE_WS_URL=
VITE_APP_NAME=helix
